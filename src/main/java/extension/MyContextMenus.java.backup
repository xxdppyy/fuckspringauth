package extension;

import burp.api.montoya.MontoyaApi;
import burp.api.montoya.http.message.HttpHeader;
import burp.api.montoya.http.message.HttpRequestResponse;
import burp.api.montoya.http.message.responses.HttpResponse;
import burp.api.montoya.http.message.requests.HttpRequest;
import burp.api.montoya.scanner.AuditResult;
import burp.api.montoya.scanner.audit.issues.AuditIssue;
import burp.api.montoya.scanner.audit.issues.AuditIssueConfidence;
import burp.api.montoya.scanner.audit.issues.AuditIssueSeverity;
import burp.api.montoya.ui.contextmenu.ContextMenuEvent;
import burp.api.montoya.ui.contextmenu.ContextMenuItemsProvider;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.*;
import javax.swing.*;

public class MyContextMenus implements ContextMenuItemsProvider {
    List<AuditIssue> activeAuditIssues = new ArrayList<AuditIssue>();
    private final MontoyaApi api;
    private final BypassLogPanel logPanel;
    private final ExecutorService executorService;

    // 内部类：存储路径和绕过类型
    private static class PathWithType {
        String path;
        String type;
        PathWithType(String path, String type) {
            this.path = path;
            this.type = type;
        }
    }

    public MyContextMenus(MontoyaApi api, BypassLogPanel logPanel) {
        this.api = api;
        this.logPanel = logPanel;
        this.executorService = Executors.newFixedThreadPool(5);
    }

    public List<AuditIssue> getActiveAuditIssues() {
        return new ArrayList<>(this.activeAuditIssues);
    }
    @Override
    public List<Component> provideMenuItems(ContextMenuEvent event) {
        List<Component> menus = new ArrayList<>();
        JMenuItem TestJMenuItem = new JMenuItem("bypass");
        TestJMenuItem.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                HttpRequestResponse requestResponse = getSelectedHttpRequestResponse(event);
                if(requestResponse != null) {
                    String nowurlpath = requestResponse.request().path();
                    List<PathWithType> allurlpaths = varyurls(nowurlpath);
                    sendlist(allurlpaths, requestResponse);

                } else{
                    api.logging().logToError("The request is not selected correctly");
                }
            }
        });
        menus.add(TestJMenuItem);
        return menus;
    }
    public  AuditResult activeAudit() {
        return AuditResult.auditResult(activeAuditIssues);
    }
    public class springbypass {


        public static String springauthbypassIssueName = "Spring bypass";
        public static String springauthbypassIssueDetail = "";
        public static AuditIssueSeverity springauthbypassIssueSeverity = AuditIssueSeverity.HIGH;
        public static AuditIssueConfidence springauthbypassIssueConfidence = AuditIssueConfidence.FIRM;
        public static AuditIssueSeverity springauthbypassIssueTypicalSeverity = AuditIssueSeverity.HIGH;

        public static String passiveSerializationIssueName = "Spring bypass";
        public static String passiveSerializationIssueDetail = "";
        public static AuditIssueSeverity passiveSerializationIssueSeverity = AuditIssueSeverity.INFORMATION;
        public static AuditIssueConfidence passiveSerializationIssueConfidence = AuditIssueConfidence.FIRM;
        public static AuditIssueSeverity passiveSerializationIssueTypicalSeverity = AuditIssueSeverity.INFORMATION;

    }
    public void sendlist(List<PathWithType> allurlpaths, HttpRequestResponse requestResponse) {
        SwingWorker<Void, Object[]> worker = new SwingWorker<Void, Object[]>() {
            private ResponseComparator comparator;

            @Override
            protected Void doInBackground() throws ExecutionException, InterruptedException {
                // 获取基准响应
                HttpResponse baselineResponse = api.http().sendRequest(requestResponse.request()).response();
                logPanel.setBaselineResponse(baselineResponse);
                comparator = new ResponseComparator(baselineResponse, 50.0);

                // 记录原始host，用于过滤
                String originalHost = requestResponse.request().httpService().host();

                List<CompletableFuture<Void>> futures = new ArrayList<>();

                // 并发执行所有测试
                futures.add(CompletableFuture.runAsync(() -> testUrlPathVariations(allurlpaths, requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testIpSpoofing(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testMethodSwitch(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testHttpProtocolBypass(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testPathNormalization(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testAuthBypass(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testParameterInjection(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testParameterNamingFuzz(requestResponse, originalHost), executorService));
                futures.add(CompletableFuture.runAsync(() -> testContentTypeConfusion(requestResponse, originalHost), executorService));

                // 等待所有任务完成
                CompletableFuture.allOf(futures.toArray(new CompletableFuture[0])).get();

                return null;
        }

            // 原始URL路径变形测试
            private void testUrlPathVariations(List<PathWithType> allurlpaths, HttpRequestResponse requestResponse, String originalHost) {
                for (PathWithType pathWithType : allurlpaths) {
                    HttpRequest request = requestResponse.request().withPath(pathWithType.path);
                    HttpResponse response = api.http().sendRequest(request).response();
                    ComparisonResult result = comparator != null ? comparator.compare(response) : null;
                    logPanel.addLog(request, response, pathWithType.type);
                    publish(new Object[]{response, request, requestResponse, result, originalHost});
                }
            }

            // IP伪造头绕过
            private void testIpSpoofing(HttpRequestResponse requestResponse, String originalHost) {
                HttpRequest ipSpoofRequest = requestResponse.request()
                    .withHeader(HttpHeader.httpHeader("Base-Url","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("Client-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Forwarded-For","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Real-Ip","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Client-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Originating-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Remote-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Remote-Addr","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-True-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("Cdn-Real-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("X-Cluster-Client-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("WL-Proxy-Client-IP","127.0.0.1"))
                    .withHeader(HttpHeader.httpHeader("Proxy-Client-IP","127.0.0.1"));
                HttpResponse ipSpoofResponse = api.http().sendRequest(ipSpoofRequest).response();
                ComparisonResult result = comparator != null ? comparator.compare(ipSpoofResponse) : null;
                logPanel.addLog(ipSpoofRequest, ipSpoofResponse, "IP Spoofing");
                publish(new Object[]{ipSpoofResponse, ipSpoofRequest, requestResponse, result, originalHost});
            }

            // HTTP方法切换
            private void testMethodSwitch(HttpRequestResponse requestResponse, String originalHost) {
                String currentMethod = requestResponse.request().method().toString();
                if (currentMethod.equals("GET")) {
                    HttpRequest request = requestResponse.request().withMethod("POST");
                    HttpResponse response = api.http().sendRequest(request).response();
                    ComparisonResult result = comparator != null ? comparator.compare(response) : null;
                    logPanel.addLog(request, response, "Method GET→POST");
                    publish(new Object[]{response, request, requestResponse, result, originalHost});
                }
                if (currentMethod.equals("POST")) {
                    HttpRequest request = requestResponse.request().withMethod("GET");
                    HttpResponse response = api.http().sendRequest(request).response();
                    ComparisonResult result = comparator != null ? comparator.compare(response) : null;
                    logPanel.addLog(request, response, "Method POST→GET");
                    publish(new Object[]{response, request, requestResponse, result, originalHost});
                }
            }

            // HTTP协议层绕过
            private void testHttpProtocolBypass(HttpRequestResponse requestResponse, String originalHost) {
                String[] hosts = {"localhost", "127.0.0.1", "0.0.0.0", "::1"};
                for (String host : hosts) {
                    HttpRequest req = requestResponse.request().withHeader(HttpHeader.httpHeader("Host", host));
                    HttpResponse resp = api.http().sendRequest(req).response();
                    ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                    logPanel.addLog(req, resp, "Host Header");
                    publish(new Object[]{resp, req, requestResponse, result, originalHost});
                }

                String originalPath = requestResponse.request().path();
                HttpRequest req1 = requestResponse.request().withPath("/").withHeader(HttpHeader.httpHeader("X-Original-URL", originalPath));
                HttpResponse resp1 = api.http().sendRequest(req1).response();
                ComparisonResult result1 = comparator != null ? comparator.compare(resp1) : null;
                logPanel.addLog(req1, resp1, "X-Original-URL");
                publish(new Object[]{resp1, req1, requestResponse, result1, originalHost});

                HttpRequest req2 = requestResponse.request().withPath("/").withHeader(HttpHeader.httpHeader("X-Rewrite-URL", originalPath));
                HttpResponse resp2 = api.http().sendRequest(req2).response();
                ComparisonResult result2 = comparator != null ? comparator.compare(resp2) : null;
                logPanel.addLog(req2, resp2, "X-Rewrite-URL");
                publish(new Object[]{resp2, req2, requestResponse, result2, originalHost});
            }

            // 路径规范化绕过
            private void testPathNormalization(HttpRequestResponse requestResponse, String originalHost) {
                String fullPath = requestResponse.request().path();

                // 分离路径和参数
                String path = fullPath.contains("?") ? fullPath.substring(0, fullPath.indexOf("?")) : fullPath;
                String query = fullPath.contains("?") ? fullPath.substring(fullPath.indexOf("?")) : "";

                List<PathWithType> bypassPaths = new ArrayList<>();

                // 分割路径段（过滤空段和参数）
                List<String> validSegments = new ArrayList<>();
                for (String seg : path.split("/")) {
                    if (!seg.isEmpty()) {
                        validSegments.add(seg);
                    }
                }

                // 在每个目录后插入/1/../或/1/..;/
                for (int i = 0; i < validSegments.size(); i++) {
                    StringBuilder pathWith1Dot = new StringBuilder();
                    StringBuilder pathWith1DotSemi = new StringBuilder();
                    for (int j = 0; j < validSegments.size(); j++) {
                        pathWith1Dot.append("/").append(validSegments.get(j));
                        pathWith1DotSemi.append("/").append(validSegments.get(j));
                        if (j == i) {
                            pathWith1Dot.append("/1/..");
                            pathWith1DotSemi.append("/1/..;");
                        }
                    }
                    bypassPaths.add(new PathWithType(pathWith1Dot.toString() + query, "Path Traversal /1/.."));
                    bypassPaths.add(new PathWithType(pathWith1DotSemi.toString() + query, "Path Traversal /1/..;"));
                }

                // URL编码每个路径段的首字母
                for (int i = 0; i < validSegments.size(); i++) {
                    StringBuilder encodedPath = new StringBuilder();
                    for (int j = 0; j < validSegments.size(); j++) {
                        encodedPath.append("/");
                        if (j == i) {
                            encodedPath.append(String.format("%%%02x", (int) validSegments.get(j).charAt(0)));
                            encodedPath.append(validSegments.get(j).substring(1));
                        } else {
                            encodedPath.append(validSegments.get(j));
                        }
                    }
                    bypassPaths.add(new PathWithType(encodedPath.toString() + query, "URL Encode First Char"));
                }

                // 大小写混淆
                if (path.length() > 1) {
                    bypassPaths.add(new PathWithType(path.substring(0, 2).toUpperCase() + path.substring(2) + query, "Case Mix"));
                    bypassPaths.add(new PathWithType(path.toUpperCase() + query, "UPPERCASE"));
                }

                // 路径参数
                bypassPaths.add(new PathWithType(path + ";name=test" + query, "Path Param ;name=test"));
                bypassPaths.add(new PathWithType(path + ";jsessionid=xxx" + query, "Path Param ;jsessionid"));
                bypassPaths.add(new PathWithType(path + ";index.jpg" + query, "Path Param ;index.jpg"));

                for (PathWithType pathWithType : bypassPaths) {
                    HttpRequest req = requestResponse.request().withPath(pathWithType.path);
                    HttpResponse resp = api.http().sendRequest(req).response();
                    ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                    logPanel.addLog(req, resp, pathWithType.type);
                    publish(new Object[]{resp, req, requestResponse, result, originalHost});
                }
            }

            // 认证令牌/会话绕过
            private void testAuthBypass(HttpRequestResponse requestResponse, String originalHost) {
                HttpRequest baseRequest = requestResponse.request();

                // 删除Authorization头
                HttpRequest noAuthRequest = baseRequest;
                for (HttpHeader header : baseRequest.headers()) {
                    if (header.name().equalsIgnoreCase("Authorization")) {
                        noAuthRequest = noAuthRequest.withRemovedHeader(header.name());
                    }
                }
                HttpResponse resp1 = api.http().sendRequest(noAuthRequest).response();
                ComparisonResult result1 = comparator != null ? comparator.compare(resp1) : null;
                logPanel.addLog(noAuthRequest, resp1, "Remove Auth");
                publish(new Object[]{resp1, noAuthRequest, requestResponse, result1, originalHost});

                // 空/无效Token
                HttpRequest nullTokenReq = baseRequest.withHeader(HttpHeader.httpHeader("Authorization", "Bearer null"));
                HttpResponse resp2 = api.http().sendRequest(nullTokenReq).response();
                ComparisonResult result2 = comparator != null ? comparator.compare(resp2) : null;
                logPanel.addLog(nullTokenReq, resp2, "Null Token");
                publish(new Object[]{resp2, nullTokenReq, requestResponse, result2, originalHost});

                HttpRequest emptyTokenReq = baseRequest.withHeader(HttpHeader.httpHeader("Authorization", "Bearer "));
                HttpResponse resp3 = api.http().sendRequest(emptyTokenReq).response();
                ComparisonResult result3 = comparator != null ? comparator.compare(resp3) : null;
                logPanel.addLog(emptyTokenReq, resp3, "Empty Token");
                publish(new Object[]{resp3, emptyTokenReq, requestResponse, result3, originalHost});

                // Cookie污染
                String existingCookie = "";
                for (HttpHeader header : baseRequest.headers()) {
                    if (header.name().equalsIgnoreCase("Cookie")) {
                        existingCookie = header.value();
                        break;
                    }
                }
                String[] cookieValues = {"admin=true", "role=admin", "isAdmin=true", "user=admin"};
                for (String cookie : cookieValues) {
                    String newCookie = existingCookie.isEmpty() ? cookie : existingCookie + "; " + cookie;
                    HttpRequest cookieRequest = baseRequest.withUpdatedHeader("Cookie", newCookie);
                    HttpResponse resp = api.http().sendRequest(cookieRequest).response();
                    ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                    logPanel.addLog(cookieRequest, resp, "Cookie Injection");
                    publish(new Object[]{resp, cookieRequest, requestResponse, result, originalHost});
                }
            }

            // 参数污染和注入
            private void testParameterInjection(HttpRequestResponse requestResponse, String originalHost) {
                String path = requestResponse.request().path();
                String body = requestResponse.request().bodyToString();
                String method = requestResponse.request().method().toString();

                // 提取URL参数
                String query = path.contains("?") ? path.substring(path.indexOf("?") + 1) : "";
                List<ParameterMutator.Parameter> urlParams = ParameterMutator.extractFromQuery(query);

                // 提取JSON参数
                List<ParameterMutator.Parameter> jsonParams = new ArrayList<>();
                if ((method.equals("POST") || method.equals("PUT")) && body.contains("{")) {
                    jsonParams = ParameterMutator.extractFromJson(body);
                }

                // 对URL参数进行变异
                for (int i = 0; i < urlParams.size(); i++) {
                    List<ParameterMutator.Mutation> mutations = ParameterMutator.generateMutations(urlParams, i, "query");
                    for (ParameterMutator.Mutation mutation : mutations) {
                        String newPath = path.contains("?") ? path.substring(0, path.indexOf("?") + 1) + mutation.mutatedContent : path + "?" + mutation.mutatedContent;
                        HttpRequest req = requestResponse.request().withPath(newPath);
                        HttpResponse resp = api.http().sendRequest(req).response();
                        ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                        logPanel.addLog(req, resp, mutation.description);
                        publish(new Object[]{resp, req, requestResponse, result, originalHost});
                    }
                }

                // 对JSON参数进行变异
                for (int i = 0; i < jsonParams.size(); i++) {
                    List<ParameterMutator.Mutation> mutations = ParameterMutator.generateMutations(jsonParams, i, "json");
                    for (ParameterMutator.Mutation mutation : mutations) {
                        HttpRequest req = requestResponse.request().withBody(mutation.mutatedContent).withUpdatedHeader("Content-Type", "application/json");
                        HttpResponse resp = api.http().sendRequest(req).response();
                        ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                        logPanel.addLog(req, resp, mutation.description);
                        publish(new Object[]{resp, req, requestResponse, result, originalHost});
                    }
                }
            }

            // 参数命名Fuzz
            private void testParameterNamingFuzz(HttpRequestResponse requestResponse, String originalHost) {
                String path = requestResponse.request().path();
                String body = requestResponse.request().bodyToString();

                // 提取所有参数
                List<String> params = extractParameters(path, body);
                if (params.isEmpty()) {
                    return;
                }

                // 组合Fuzz：一次转换所有参数
                String[] namingStyles = {"snake_case", "camelCase", "UPPERCASE", "PascalCase"};

                for (String style : namingStyles) {
                    String newPath = path;
                    String newBody = body;

                    // 转换所有参数
                    for (String param : params) {
                        String variant = ParameterNamingConverter.convertNaming(param, style);
                        newPath = newPath.replaceAll("\\b" + param + "=", variant + "=");
                        newBody = newBody.replaceAll("\"" + param + "\"", "\"" + variant + "\"");
                    }

                    // 发送请求
                    HttpRequest req = requestResponse.request().withPath(newPath);
                    if (!newBody.equals(body)) {
                        req = req.withBody(newBody);
                    }

                    HttpResponse resp = api.http().sendRequest(req).response();
                    ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                    logPanel.addLog(req, resp, "Param Naming: " + style);
                    publish(new Object[]{resp, req, requestResponse, result, originalHost});
                }
            }

            // 生成参数命名变体
            private List<String> generateNamingVariants(String param) {
                List<String> variants = new ArrayList<>();

                // snake_case: userid → user_id
                if (param.length() > 2) {
                    String snakeCase = param.replaceAll("([a-z])([A-Z])", "$1_$2").toLowerCase();
                    if (param.matches(".*[a-z][a-z]+.*")) {
                        int mid = param.length() / 2;
                        snakeCase = param.substring(0, mid) + "_" + param.substring(mid);
                    }
                    variants.add(snakeCase);
                }

                // camelCase: userid → userId
                if (param.length() > 2) {
                    String camelCase = param.substring(0, param.length() - 2) +
                                      Character.toUpperCase(param.charAt(param.length() - 2)) +
                                      param.charAt(param.length() - 1);
                    variants.add(camelCase);
                }

                // UPPERCASE: userid → USERID
                variants.add(param.toUpperCase());

                // PascalCase: userid → UserId
                if (param.length() > 2) {
                    String pascalCase = Character.toUpperCase(param.charAt(0)) +
                                       param.substring(1, param.length() - 2) +
                                       Character.toUpperCase(param.charAt(param.length() - 2)) +
                                       param.charAt(param.length() - 1);
                    variants.add(pascalCase);
                }

                return variants;
            }

            // 提取所有参数名
            private List<String> extractParameters(String path, String body) {
                List<String> params = new ArrayList<>();

                // 从URL提取
                if (path.contains("?")) {
                    String query = path.substring(path.indexOf("?") + 1);
                    String[] pairs = query.split("&");
                    for (String pair : pairs) {
                        if (pair.contains("=")) {
                            String param = pair.substring(0, pair.indexOf("="));
                            if (!params.contains(param)) {
                                params.add(param);
                            }
                        }
                    }
                }

                // 从JSON Body提取
                if (body.contains("{") && body.contains(":")) {
                    String[] parts = body.split("\"");
                    for (int i = 0; i < parts.length - 1; i++) {
                        if (parts[i + 1].startsWith(":") || parts[i + 1].trim().startsWith(":")) {
                            String param = parts[i];
                            if (param.matches("[a-zA-Z_][a-zA-Z0-9_]*") && !params.contains(param)) {
                                params.add(param);
                            }
                        }
                    }
                }

                return params;
            }

            // Content-Type混淆
            private void testContentTypeConfusion(HttpRequestResponse requestResponse, String originalHost) {
                String method = requestResponse.request().method().toString();
                if (!method.equals("POST") && !method.equals("PUT") && !method.equals("PATCH")) {
                    return;
                }

                String[] contentTypes = {
                    "text/plain",
                    "application/x-www-form-urlencoded",
                    "multipart/form-data",
                    "text/xml",
                    "application/xml"
                };

                for (String contentType : contentTypes) {
                    HttpRequest req = requestResponse.request().withUpdatedHeader("Content-Type", contentType);
                    HttpResponse resp = api.http().sendRequest(req).response();
                    ComparisonResult result = comparator != null ? comparator.compare(resp) : null;
                    logPanel.addLog(req, resp, "Content-Type: " + contentType);
                    publish(new Object[]{resp, req, requestResponse, result, originalHost});
                }
            }

            @Override
            protected void process(List<Object[]> chunks) {
                for (Object[] chunk : chunks) {
                    HttpResponse response = (HttpResponse) chunk[0];
                    HttpRequest request = (HttpRequest) chunk[1];
                    HttpRequestResponse RequestResponse = (HttpRequestResponse) chunk[2];
                    ComparisonResult result = chunk.length > 3 ? (ComparisonResult) chunk[3] : null;
                    String originalHost = chunk.length > 4 ? (String) chunk[4] : null;

                    // 验证host是否匹配原始目标
                    if (originalHost != null && !request.httpService().host().equals(originalHost)) {
                        continue; // 跳过不同host的请求
                    }

                    // 简化判断：新响应为2xx且有显著差异即报告
                    boolean shouldAddIssue = false;

                    if (result != null && response.statusCode() >= 200 && response.statusCode() < 300) {
                        // 条件：状态码2xx + (SUCCESS/SUSPICIOUS 或 diff>=50%)
                        if (result.getStatus() == ComparisonResult.Status.SUCCESS ||
                            result.getStatus() == ComparisonResult.Status.SUSPICIOUS ||
                            result.getLengthDiffPercent() >= 50.0) {
                            shouldAddIssue = true;
                        }
                    }

                    if (shouldAddIssue) {
                        HttpRequestResponse testRequestResponse = HttpRequestResponse.httpRequestResponse(request, response);
                        AuditIssue auditIssue = AuditIssue.auditIssue(
                                springbypass.springauthbypassIssueName,
                                "Bypass Type: " + result.getStatus() + "\nReason: " + result.getReason(),
                                null,
                                request.url(),
                                springbypass.springauthbypassIssueSeverity,
                                springbypass.springauthbypassIssueConfidence,
                                null,
                                null,
                                springbypass.springauthbypassIssueTypicalSeverity,
                                testRequestResponse);
                        activeAuditIssues.add(auditIssue);
                        api.siteMap().add(testRequestResponse);
                    }
                }
            }
            @Override
            protected void done() {
                try {
                    get();
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
        };
        worker.execute();
//        api.logging().logToOutput(String.valueOf(requestResponse.response().statusCode()));

    }
    private HttpRequestResponse getSelectedHttpRequestResponse(ContextMenuEvent event) {
        // 获取当前选中的 HttpRequestResponse 对象
        return event.messageEditorRequestResponse().isPresent()
                ? event.messageEditorRequestResponse().get().requestResponse()
                : event.selectedRequestResponses().isEmpty() ? null : event.selectedRequestResponses().get(0);
    }
    private  List<PathWithType> varyurls(String urlpath) {
        List<PathWithType> allurlpaths = new ArrayList<>();
        if(!urlpath.isEmpty()){

            // 1. 最后一个目录加上 /
            String withTrailingSlash = urlpath.replaceAll("([^/?]+)(\\?.*)?$", "$1/$2");
            allurlpaths.add(new PathWithType(withTrailingSlash, "Trailing Slash"));

            // 2. 最后一个目录加上 .json
            String withJson = urlpath.replaceAll("([^/?]+)(\\?.*)?$", "$1.json$2");
            allurlpaths.add(new PathWithType(withJson, ".json Extension"));

            // 3. 最后一个目录加上 .111
            String with111 = urlpath.replaceAll("([^/?]+)(\\?.*)?$", "$1.111$2");
            allurlpaths.add(new PathWithType(with111, ".111 Extension"));

            if (!urlpath.contains("?")) {
                allurlpaths.add(new PathWithType(urlpath + "?id=1", "?id=1 Parameter"));
                allurlpaths.add(new PathWithType(urlpath + "?role=1", "?role=1 Parameter"));
                allurlpaths.add(new PathWithType(urlpath + "?roleType=admin", "?roleType=admin Parameter"));
            }

            // 5. 最后一个目录加上 /%0d
            String withCR = urlpath.replaceAll("([^/?]+)(\\?.*)?$", "$1%0d$2");
            allurlpaths.add(new PathWithType(withCR, "%0d Injection"));

            // 7. 一个一个 / 变为 /;/
            for (int i = 0; i < urlpath.length(); i++) {
                if (urlpath.charAt(i) == '/') {
                    String modifiedPath = urlpath.substring(0, i) + "/;" + urlpath.substring(i);
                    allurlpaths.add(new PathWithType(modifiedPath, "/;/ Injection"));
                }
            }
            // 8. 一个一个 / 变成 //;//
            for (int i = 0; i < urlpath.length(); i++) {
                if (urlpath.charAt(i) == '/') {
                    String modifiedPath = urlpath.substring(0, i) + "//;/" + urlpath.substring(i);
                    allurlpaths.add(new PathWithType(modifiedPath, "//;/ Injection"));
                }
            }
        }else {
            api.logging().logToError("The url is empty");
        }
        return  allurlpaths;
    }
}